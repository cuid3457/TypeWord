# ============================================================
# Typeword - Environment Variables Template
# ============================================================
# Copy this file to .env.local and fill in real values.
# EXPO_PUBLIC_ prefixed vars are bundled into the client app.
# ============================================================

# ---- Supabase (client) ----
# Dashboard → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# ---- OpenAI (Edge Function secret, NOT client) ----
# https://platform.openai.com/api-keys
# Do NOT commit this. Set via: supabase secrets set OPENAI_API_KEY=...
# OPENAI_API_KEY=

# ---- Supabase Service Role (Edge Function only) ----
# Dashboard → Project Settings → API → service_role
# Do NOT commit. Do NOT put in client.
# SUPABASE_SERVICE_ROLE_KEY=

# ---- RevenueCat (in-app purchases) ----
# https://app.revenuecat.com → Project → API Keys
EXPO_PUBLIC_RC_IOS_KEY=
EXPO_PUBLIC_RC_ANDROID_KEY=

# ---- Sentry (crash reporting) ----
# https://sentry.io → Project Settings → Client Keys (DSN)
EXPO_PUBLIC_SENTRY_DSN=
