{
  "expo": {
    "name": "TypeWord",
    "slug": "typeword",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "typeword",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.typeword.app",
      "infoPlist": {
        "NSUserTrackingUsageDescription": "This identifier will be used to deliver personalized ads to you."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2EC4A5",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "app.typeword.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#1A1A1A"
          }
        }
      ],
      "expo-localization",
      "@react-native-google-signin/google-signin",
      "expo-tracking-transparency",
      "expo-sqlite",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-2786267266321015~8426162844",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511"
        }
      ],
      [
        "@sentry/react-native",
        {
          "organization": "typeword",
          "project": "react-native"
        }
      ],
      "./plugins/adi-registration",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow TypeWord to use the microphone for voice search.",
          "speechRecognitionPermission": "Allow TypeWord to use speech recognition for voice search."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "dcfebb54-591a-425d-b9db-f30647c85bd6"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/dcfebb54-591a-425d-b9db-f30647c85bd6"
    }
  }
}
