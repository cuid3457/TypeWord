# Cloudflare Pages security headers for moavoca.com
#
# Two tiers:
#   /*                — non-breaking, site-wide hardening (safe for the Expo
#                       Web SPA at /app/*, which loads inline bootstrap JS +
#                       inline RN-web styles and connects cross-origin to
#                       Supabase/Sentry/RevenueCat — so we deliberately do
#                       NOT set a restrictive default-src/script-src/connect-src
#                       here; that would break the app).
#   static .html      — the marketing/legal pages have ZERO JavaScript and
#                       load no external resources, so they get a strict
#                       lock-down CSP that overrides the /* CSP.
#
# The Expo Web SPA at /app/* still gets the lax /* CSP. When adding AdSense
# ads to the SPA itself, add an explicit script-src + connect-src + frame-src
# CSP scoped to /app/* and TEST the SPA against it (see project_web_adsense_plan).
#
# AdSense verification is hosted on / (index.html) — CSP for that path
# allowlists googlesyndication / doubleclick / adtrafficquality.

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: frame-ancestors 'none'; object-src 'none'; base-uri 'self'

# Universal Link / App Link verification files. _redirects proxies the
# canonical /.well-known/* paths to /well-known/* (CF Pages drops
# dotfile dirs at deploy). _headers matches by destination path, so the
# Content-Type and cache rules are pinned to the dotless paths.
# apple-app-site-association has no extension so CF Pages cannot infer
# the MIME from the file name.
/well-known/apple-app-site-association
  Content-Type: application/json
  Cache-Control: public, max-age=3600

/well-known/assetlinks.json
  Content-Type: application/json
  Cache-Control: public, max-age=3600

# SPA cache policy
#
# Expo Web emits hash-named static assets (entry-<sha>.js, foo-<sha>.js)
# that are content-addressed and safe to long-cache. But the SPA shell
# at /app/<route> is served via the _redirects rewrite to /app/index.html,
# and CF Pages' default for rewritten HTML is `public, s-maxage=604800`
# (7d edge). When a fresh deploy replaces chunk hashes, any user landing
# on an edge-cached old shell gets HTML referencing dead chunks. The
# `/app/*` SPA fallback then serves index.html with text/html for the
# missing chunk URL, and the browser fails to parse HTML as a JS module
# ("Loading module … failed").
#
# Order matters: CF Pages merges all matching rules and later ones win
# on the same header name. Static chunks rule must come AFTER the SPA
# shell rule so it overrides for `/app/_expo/*`.
/app/*
  Cache-Control: public, max-age=0, must-revalidate

/app/_expo/*
  Cache-Control: public, max-age=31536000, immutable

/
  Content-Security-Policy: default-src 'none'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com https://pagead2.googlesyndication.com https://*.googlesyndication.com https://*.adtrafficquality.google; style-src 'unsafe-inline' https://cdn.jsdelivr.net; img-src 'self' data: https://*.googlesyndication.com https://*.doubleclick.net https://*.google.com https://*.adtrafficquality.google; font-src https://cdn.jsdelivr.net; connect-src 'self' https://cloudflareinsights.com https://*.googlesyndication.com https://*.doubleclick.net https://*.google.com https://*.adtrafficquality.google; frame-src https://googleads.g.doubleclick.net https://tpc.googlesyndication.com https://*.googlesyndication.com https://*.adtrafficquality.google https://*.google.com; base-uri 'none'; form-action 'none'; frame-ancestors 'none'

/index.html
  Content-Security-Policy: default-src 'none'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com https://pagead2.googlesyndication.com https://*.googlesyndication.com https://*.adtrafficquality.google; style-src 'unsafe-inline' https://cdn.jsdelivr.net; img-src 'self' data: https://*.googlesyndication.com https://*.doubleclick.net https://*.google.com https://*.adtrafficquality.google; font-src https://cdn.jsdelivr.net; connect-src 'self' https://cloudflareinsights.com https://*.googlesyndication.com https://*.doubleclick.net https://*.google.com https://*.adtrafficquality.google; frame-src https://googleads.g.doubleclick.net https://tpc.googlesyndication.com https://*.googlesyndication.com https://*.adtrafficquality.google https://*.google.com; base-uri 'none'; form-action 'none'; frame-ancestors 'none'

