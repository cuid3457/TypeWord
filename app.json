{
  "expo": {
    "name": "MoaVoca",
    "slug": "typeword",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "typeword",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2EC4A5",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "app.typeword.app",
      "allowBackup": false,
      "googleServicesFile": "./android/app/google-services.json",
      "permissions": ["com.android.vending.BILLING"]
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.typeword.app",
      "buildNumber": "9",
      "appleTeamId": "5UDNYL5YTJ",
      "usesAppleSignIn": true,
      "googleServicesFile": "./ios/TypeWord/GoogleService-Info.plist",
      "infoPlist": {
        "NSUserTrackingUsageDescription": "This identifier will be used to deliver personalized ads to you.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#2EC4A5",
          "dark": {
            "backgroundColor": "#2EC4A5"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#2EC4A5"
        }
      ],
      "expo-localization",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.518104064870-rksfiejtdq0o3cto25ftjkcf8pteblud"
        }
      ],
      "expo-tracking-transparency",
      "expo-sqlite",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-2786267266321015~8426162844",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511"
        }
      ],
      [
        "@sentry/react-native",
        {
          "organization": "typeword",
          "project": "react-native"
        }
      ],
      "./plugins/adi-registration",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow MoaVoca to use the microphone for voice search.",
          "speechRecognitionPermission": "Allow MoaVoca to use speech recognition for voice search."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "MoaVoca accesses your photo library to extract words from images for vocabulary learning.",
          "cameraPermission": "MoaVoca uses your camera to capture text and extract words for vocabulary learning."
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-audio",
      "expo-apple-authentication"
    ],
    "experiments": {
      "typedRoutes": true,
      "baseUrl": "/app"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "dcfebb54-591a-425d-b9db-f30647c85bd6"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": false,
      "url": "https://u.expo.dev/dcfebb54-591a-425d-b9db-f30647c85bd6"
    }
  }
}
